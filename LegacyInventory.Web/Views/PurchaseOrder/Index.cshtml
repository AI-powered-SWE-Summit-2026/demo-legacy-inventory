@model IEnumerable<PurchaseOrder>
@{
    ViewData["Title"] = "Purchase Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2">Purchase Orders</h1>
    <a asp-action="Create" class="btn btn-primary">Create Purchase Order</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Order Number</th>
            <th>Supplier</th>
            <th>Status</th>
            <th>Order Date</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.OrderNumber</td>
            <td>@item.Supplier?.Name</td>
            <td>@item.Status</td>
            <td>@item.OrderDate.ToString("yyyy-MM-dd")</td>
            <td>@item.TotalAmount.ToString("C")</td>
            <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a></td>
        </tr>
    }
    </tbody>
</table>
