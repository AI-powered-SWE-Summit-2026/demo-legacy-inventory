@model IEnumerable<Warehouse>
@{
    ViewData["Title"] = "Warehouses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2">Warehouses</h1>
    <a asp-action="Create" class="btn btn-primary">Create Warehouse</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="thead-light">
        <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Manager</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Location</td>
            <td>@item.Capacity</td>
            <td>@item.ManagerName</td>
            <td>@(item.IsActive ? "Active" : "Inactive")</td>
        </tr>
    }
    </tbody>
</table>
