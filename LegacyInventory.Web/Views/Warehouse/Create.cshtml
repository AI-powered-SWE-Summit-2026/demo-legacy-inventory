@model Warehouse
@{
    ViewData["Title"] = "Create Warehouse";
}

<h1 class="h2 mb-3">Create Warehouse</h1>

<form asp-action="Create" method="post">
    <div class="form-row">
        <div class="form-group col-md-6">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="form-group col-md-6">
            <label asp-for="Location"></label>
            <input asp-for="Location" class="form-control" />
        </div>
    </div>
    <div class="form-row">
        <div class="form-group col-md-4">
            <label asp-for="Capacity"></label>
            <input asp-for="Capacity" class="form-control" />
        </div>
        <div class="form-group col-md-4">
            <label asp-for="ManagerName"></label>
            <input asp-for="ManagerName" class="form-control" />
        </div>
        <div class="form-group col-md-4 d-flex align-items-center">
            <div class="form-check mt-4">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Back</a>
</form>
