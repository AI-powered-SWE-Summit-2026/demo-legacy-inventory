@model IEnumerable<StockLevel>
@using Newtonsoft.Json
@using System.Linq
@{
    ViewData["Title"] = "Stock";
    var lowStock = (IEnumerable<StockLevel>)ViewBag.LowStock;
    var lowStockJson = JsonConvert.SerializeObject(lowStock.Select(x => new
    {
        Product = x.Product.Name,
        Warehouse = x.Warehouse.Name,
        Available = x.Quantity - x.ReservedQuantity
    }).ToList());
}

<h1 class="h2 mb-3">Stock Levels</h1>

<div class="alert alert-warning">
    <strong>Low stock items:</strong> @lowStock.Count()
</div>

<table class="table table-striped table-bordered">
    <thead class="thead-light">
        <tr>
            <th>Product</th>
            <th>Warehouse</th>
            <th>Category</th>
            <th>Quantity</th>
            <th>Reserved</th>
            <th>Available</th>
            <th>Last Updated</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr class="@((item.Quantity - item.ReservedQuantity) <= item.Product.ReorderLevel ? "table-danger" : string.Empty)">
            <td>@item.Product?.Name</td>
            <td>@item.Warehouse?.Name</td>
            <td>@item.Product?.Category?.Name</td>
            <td>@item.Quantity</td>
            <td>@item.ReservedQuantity</td>
            <td>@(item.Quantity - item.ReservedQuantity)</td>
            <td>@item.LastUpdated.ToString("yyyy-MM-dd")</td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
<script>
    var lowStockSnapshot = @Html.Raw(lowStockJson);
    console.log('Low stock snapshot', lowStockSnapshot);
</script>
}
