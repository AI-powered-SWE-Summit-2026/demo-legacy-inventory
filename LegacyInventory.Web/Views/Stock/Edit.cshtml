@model StockLevel
@{
    ViewData["Title"] = "Adjust Stock";
}

<h1 class="h2 mb-3">Adjust Stock</h1>

<dl class="row">
    <dt class="col-sm-3">Product</dt>
    <dd class="col-sm-9">@Model.Product?.Name</dd>
    <dt class="col-sm-3">Warehouse</dt>
    <dd class="col-sm-9">@Model.Warehouse?.Name</dd>
</dl>

<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="ProductId" type="hidden" />
    <input asp-for="WarehouseId" type="hidden" />
    <div class="form-row">
        <div class="form-group col-md-4">
            <label asp-for="Quantity"></label>
            <input asp-for="Quantity" class="form-control" type="number" min="0" />
        </div>
        <div class="form-group col-md-4">
            <label asp-for="ReservedQuantity"></label>
            <input asp-for="ReservedQuantity" class="form-control" type="number" min="0" />
        </div>
        <div class="form-group col-md-4">
            <label asp-for="LastUpdated"></label>
            <input asp-for="LastUpdated" class="form-control" type="datetime-local" />
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Save Adjustment</button>
    <a asp-action="Index" class="btn btn-link">Back</a>
</form>
