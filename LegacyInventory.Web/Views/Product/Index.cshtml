@model IEnumerable<Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2">Products</h1>
    <a asp-action="Create" class="btn btn-primary">Create Product</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Name</th>
            <th>SKU</th>
            <th>Category</th>
            <th>Supplier</th>
            <th>Unit Price</th>
            <th>Reorder Level</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.SKU</td>
            <td>@item.Category?.Name</td>
            <td>@item.Supplier?.Name</td>
            <td>@item.UnitPrice.ToString("C")</td>
            <td>@item.ReorderLevel</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>
