@model Product
@{
    ViewData["Title"] = "Product Details";
}

<h1 class="h2 mb-3">@Model.Name</h1>

<div class="row">
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">SKU</dt>
            <dd class="col-sm-9">@Model.SKU</dd>
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>
            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.Name</dd>
            <dt class="col-sm-3">Supplier</dt>
            <dd class="col-sm-9">@Model.Supplier?.Name</dd>
            <dt class="col-sm-3">Stored Price</dt>
            <dd class="col-sm-9">@Model.UnitPrice.ToString("C")</dd>
            <dt class="col-sm-3">WCF Price</dt>
            <dd class="col-sm-9">@(((decimal)ViewBag.LivePrice).ToString("C"))</dd>
            <dt class="col-sm-3">Reorder Level</dt>
            <dd class="col-sm-9">@Model.ReorderLevel</dd>
        </dl>
    </div>
</div>

<h2 class="h4 mt-4">Warehouse Stock</h2>
<table class="table table-sm table-bordered">
    <thead>
        <tr>
            <th>Warehouse</th>
            <th>Quantity</th>
            <th>Reserved</th>
            <th>Last Updated</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var stock in Model.StockLevels)
    {
        <tr>
            <td>@stock.Warehouse?.Name</td>
            <td>@stock.Quantity</td>
            <td>@stock.ReservedQuantity</td>
            <td>@stock.LastUpdated.ToString("yyyy-MM-dd")</td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
<a asp-action="Index" class="btn btn-link">Back</a>
